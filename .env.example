# Supabase CLI / remote database migration.
# Copy this file to .env and fill the values locally. Do not commit .env.
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_ACCESS_TOKEN=<personal-access-token>
SUPABASE_DB_PASSWORD=<database-password>

# Supabase REST write access for the shadow sync service.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<server-side-service-role-key>

# Existing Apps Script API used as the read-only source during shadow migration.
APPS_SCRIPT_API_URL=https://script.google.com/macros/s/<deployment-id>/exec
SUPABASE_SYNC_BATCH_SIZE=500
APPS_SCRIPT_PAGE_LIMIT=5000
SYNC_REQUEST_TIMEOUT_MS=60000
SYNC_LEASE_NAME=daily-sync
SYNC_LEASE_TTL_SECONDS=2400
